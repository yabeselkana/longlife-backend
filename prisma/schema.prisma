generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  phone         String?
  city          String?
  identity_id   String?
  avatar        String?
  address       String?
  country       String?
  province      String?
  district      String?
  sub_district  String?
  village       String?
  rw            String?
  rt            String?
  occupation    String?
  bank_name     String?
  bank_account  String?
  bank_owner    String?
  status        Status   @default(ACTIVE)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  members       Member[]
  invitations   Invitation[]
}

model Member {
  id             String       @id @default(uuid())
  name           String
  email          String       @unique
  password_hash  String
  phone          String?
  city           String?
  identity_id    String?
  avatar         String?
  address        String?
  country        String?
  province       String?
  district       String?
  sub_district   String?
  village        String?
  rw             String?
  rt             String?
  occupation     String?
  bank_name      String?
  bank_account   String?
  bank_owner     String?
  status         Status       @default(ACTIVE)
  admin_id       String       // The admin who registered this member or acts as root
  parent_id      String?      // Downline parent (for binary tree)
  personal_sales Decimal      @default(0.00) @db.Decimal(10, 2)
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  admin          Admin        @relation(fields: [admin_id], references: [id])
  parent         Member?      @relation("MemberToMember", fields: [parent_id], references: [id])
  children       Member[]     @relation("MemberToMember")

  commissions    Commission[]
  invitations    Invitation[]
  orders         Order[]
}

model Inventory {
  sku        String   @id
  name       String
  price      Decimal  @db.Decimal(10, 2)
  cost       Decimal  @db.Decimal(10, 2)
  stock      Int      @default(0)
  sold       Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  orders     Order[]
}

model Order {
  id           Int          @id @default(autoincrement())
  member_id    String
  sku          String
  qty          Int
  total_amount Decimal      @db.Decimal(10, 2)
  status       OrderStatus  @default(PENDING)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  commissions  Commission[]
  member       Member       @relation(fields: [member_id], references: [id])
  product      Inventory    @relation(fields: [sku], references: [sku])
}

model Commission {
  id               Int              @id @default(autoincrement())
  member_id        String
  related_order_id Int?
  type             String           @default("Network Bonus")
  amount           Decimal          @db.Decimal(10, 2)
  status           CommissionStatus @default(PENDING)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  member           Member           @relation(fields: [member_id], references: [id])
  order            Order?           @relation(fields: [related_order_id], references: [id])
}

model Invitation {
  id         Int              @id @default(autoincrement())
  code       String           @unique
  parent_id  String?
  admin_id   String?
  status     InvitationStatus @default(PENDING)
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
  parent     Member?          @relation(fields: [parent_id], references: [id])
  admin      Admin?           @relation(fields: [admin_id], references: [id])
}

model Expense {
  id          Int           @id @default(autoincrement())
  date        DateTime      @default(now())
  category    String
  description String?
  amount      Decimal       @db.Decimal(10, 2)
  status      ExpenseStatus @default(PAID)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
}

enum Status {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  APPROVED
  SHIPPED
  CANCELLED
}

enum CommissionStatus {
  PENDING
  PAID
  CANCELLED
}

enum InvitationStatus {
  PENDING
  USED
  CANCELLED
}

enum ExpenseStatus {
  PENDING
  PROCESSING
  PAID
}

model SystemSetting {
  id                         Int      @id @default(autoincrement())
  base_commission_percentage Decimal  @default(25.00) @db.Decimal(5, 2)
  halving_logic              String   @default("Standard")
  reduction_factor           Decimal  @default(0.50) @db.Decimal(3, 2)
  max_depth_limit            Int      @default(10)
  effective_date             DateTime @default(now())
  
  min_payout_threshold       Decimal  @default(500000.00) @db.Decimal(15, 2)
  supported_methods          String   @default("Bank Transfer")
  payout_cycle               String   @default("Weekly")
  automatic_approvals        Boolean  @default(false)

  max_order_limit            Int      @default(50)
  low_stock_threshold        Int      @default(20)
  invite_expiration_days     Int      @default(7)
  
  system_lock                Boolean  @default(false)
  
  updated_at                 DateTime @updatedAt
}
